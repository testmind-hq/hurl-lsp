{
  "name": "vscode-hurl",
  "displayName": "Hurl",
  "description": "VSCode support for Hurl powered by hurl-lsp",
  "version": "0.1.5",
  "publisher": "yuchou87",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/testmind-hq/hurl-lsp.git"
  },
  "homepage": "https://github.com/testmind-hq/hurl-lsp",
  "bugs": {
    "url": "https://github.com/testmind-hq/hurl-lsp/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:hurl",
    "onCommand:hurl.restartLanguageServer",
    "onCommand:hurl.showLog",
    "onCommand:hurl.showRequestLog"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "hurl",
        "aliases": ["Hurl", "hurl"],
        "extensions": [".hurl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hurl",
        "scopeName": "source.hurl",
        "path": "./syntaxes/hurl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "hurl",
        "path": "./snippets/hurl.json"
      }
    ],
    "configuration": {
      "title": "Hurl",
      "properties": {
        "hurl.server.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a local hurl-lsp binary."
        },
        "hurl.server.trace": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace LSP communication for debugging."
        },
        "hurl.run.verbosity": {
          "type": "string",
          "enum": ["verbose", "very-verbose"],
          "default": "verbose",
          "description": "Verbosity level for running hurl requests from CodeLens."
        },
        "hurl.run.log.clearOnRun": {
          "type": "boolean",
          "default": false,
          "description": "Clear request log output before each new run."
        },
        "hurl.run.log.maxRuns": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "Maximum number of recent runs kept in Hurl Request Log."
        },
        "hurl.run.log.maxCharsPerRun": {
          "type": "number",
          "default": 6000,
          "minimum": 0,
          "description": "Maximum characters per run chunk in request logs. Set 0 to disable truncation."
        }
      }
    },
    "commands": [
      {
        "command": "hurl.restartLanguageServer",
        "title": "Hurl: Restart Language Server"
      },
      {
        "command": "hurl.showLog",
        "title": "Hurl: Show Log"
      },
      {
        "command": "hurl.showRequestLog",
        "title": "Hurl: Show Request Log"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4",
    "@vscode/vsce": "^3.0.0"
  }
}

{
  "name": "vscode-hurl",
  "displayName": "Hurl",
  "description": "VSCode support for Hurl powered by hurl-lsp",
  "version": "0.1.11",
  "publisher": "testmind-hq",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/testmind-hq/hurl-lsp.git"
  },
  "homepage": "https://github.com/testmind-hq/hurl-lsp",
  "bugs": {
    "url": "https://github.com/testmind-hq/hurl-lsp/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:hurl",
    "onCommand:hurl.restartLanguageServer",
    "onCommand:hurl.showLog",
    "onCommand:hurl.showRequestLog",
    "onCommand:hurl.openWebviewPanel",
    "onCommand:hurl.formatDocument",
    "onCommand:hurl.exportAsMarkdown",
    "onCommand:hurl.clearRunAlerts",
    "onView:hurlRequests"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "hurl",
        "aliases": ["Hurl", "hurl"],
        "extensions": [".hurl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hurl",
        "scopeName": "source.hurl",
        "path": "./syntaxes/hurl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "hurl",
        "path": "./snippets/hurl.json"
      }
    ],
    "configuration": {
      "title": "Hurl",
      "properties": {
        "hurl.server.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a local hurl-lsp binary."
        },
        "hurl.server.trace": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace LSP communication for debugging."
        },
        "hurl.run.verbosity": {
          "type": "string",
          "enum": ["verbose", "very-verbose"],
          "default": "verbose",
          "description": "Verbosity level for running hurl requests from CodeLens."
        },
        "hurl.run.log.clearOnRun": {
          "type": "boolean",
          "default": false,
          "description": "Clear request log output before each new run."
        },
        "hurl.run.log.maxRuns": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "Maximum number of recent runs kept in Hurl Request Log."
        },
        "hurl.run.log.maxCharsPerRun": {
          "type": "number",
          "default": 6000,
          "minimum": 0,
          "description": "Maximum characters per run chunk in request logs. Set 0 to disable truncation."
        },
        "hurl.run.inlineFailureDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Show inline red diagnostics when Run/Run Chain execution fails."
        },
        "hurl.outline.groupMode": {
          "type": "string",
          "enum": ["hierarchical", "flat"],
          "default": "hierarchical",
          "description": "Outline grouping mode."
        },
        "hurl.outline.sortMode": {
          "type": "string",
          "enum": ["source", "priority"],
          "default": "source",
          "description": "Outline sorting mode."
        }
      }
    },
    "commands": [
      {
        "command": "hurl.restartLanguageServer",
        "title": "Hurl: Restart Language Server"
      },
      {
        "command": "hurl.showLog",
        "title": "Hurl: Show Log"
      },
      {
        "command": "hurl.showRequestLog",
        "title": "Hurl: Show Request Log"
      },
      {
        "command": "hurl.openWebviewPanel",
        "title": "Hurl: Open Webview Panel"
      },
      {
        "command": "hurl.exportAsMarkdown",
        "title": "Hurl: Export as Markdown"
      },
      {
        "command": "hurl.formatDocument",
        "title": "Hurl: Format Document"
      },
      {
        "command": "hurl.clearRunAlerts",
        "title": "Hurl: Clear Run Alerts"
      },
      {
        "command": "hurl.outline.runEntry",
        "title": "Run Request Entry",
        "icon": "$(play)"
      },
      {
        "command": "hurl.outline.runChain",
        "title": "Run Request Chain (with dependencies)",
        "icon": "$(debug-continue)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "hurlRequests",
          "name": "Hurl Requests",
          "when": "editorLangId == hurl || resourceExtname == .hurl"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "hurl.outline.runEntry",
          "when": "view == hurlRequests && viewItem == hurlOutlineEntry",
          "group": "inline@1"
        },
        {
          "command": "hurl.outline.runChain",
          "when": "view == hurlRequests && viewItem == hurlOutlineEntry",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "test:webview": "npm run build && node --test test/*.test.cjs",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4",
    "@vscode/vsce": "^3.0.0"
  }
}
